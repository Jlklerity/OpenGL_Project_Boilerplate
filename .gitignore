.vs/
*.sln
*.suo
*.user
*.vcxproj
*.vcxproj.filters

# Visual Studio Code
.vscode/

# CLion / JetBrains
.idea/
cmake-build-*/

# Xcode (macOS)
*.xcodeproj/
*.xcworkspace/
xcuserdata/

