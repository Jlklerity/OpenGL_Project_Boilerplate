CMakeCache.txt
CMakeFiles/
CMakeScripts/
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/

# =========================
# Compiled Binaries & Libs
# =========================
# Windows
*.exe
*.dll
*.lib
*.exp
*.pdb
*.obj
*.ilk

# macOS / Linux
*.app
*.o
*.a
*.so
*.dylib
*.out

# =========================
